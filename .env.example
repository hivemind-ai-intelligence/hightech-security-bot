# ────────────────────────────────────────────────────────────
# 🦇 𝕳𝖎-𝕿𝖊𝖈𝖍 𝕾𝖊𝖈𝖚𝖗𝖎𝖙𝖞 — Global Discord Bot
# Copy to .env and set your bot token
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# ── Discord (REQUIRED) ──────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
BOT_PREFIX=!

# ── Optional: Threat Intelligence API Keys ─────────────────
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
ALIENVAULT_OTX_API_KEY=

# ── Optional: Email for Verification OTP ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Optional: Webhook Server ────────────────────────────────
WEBHOOK_PORT=8080
WEBHOOK_API_KEY=
WEBHOOK_BIND_ADDR=0.0.0.0
DISCORD_ALERT_WEBHOOK_URL=

# ── Optional: Default channel IDs (fallback) ────────────────
AUDIT_LOG_CHANNEL_ID=0
ALERT_CHANNEL_ID=0
THREAT_INTEL_CHANNEL_ID=0
INCIDENT_CHANNEL_ID=0
WELCOME_CHANNEL_ID=0

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=data/bot.log
